# Port the dashboard is served on over the LAN
PORT=8075

# --- HamLog integration (used by the /api proxy once built; safe to leave blank until then) ---
# Base URL of your HamLog instance on the LAN
HAMLOG_URL=http://192.168.1.62:8050
# HamLog login the proxy uses to obtain a JWT server-side (never shipped to the browser)
HAMLOG_USER=
HAMLOG_PASS=
